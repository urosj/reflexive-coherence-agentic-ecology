          "required": ["binary_sha256", "command", "jsonschema", "process_environment", "pytest", "python"],
          "type": "object"
        },
        "iteration_id": {"const": "P2-I3-I05"},
        "lane_id": {"const": "AE01-L03"},
        "launch_head_binding_method": {"const": "runtime_expected_head_verified_clean_and_retained_in_claim_and_receipt"},
        "normalized_command_prefix": {
          "const": [
            ".venv/bin/python",
            "experiments/2026-07-AE01-post-n30-demand-composition-atlas/scripts/p2_i3_i05_br_one_shot.py",
            "--policy",
            "experiments/2026-07-AE01-post-n30-demand-composition-atlas/configs/p2_i3_br_i05_one_shot_policy.json",
            "--activation",
            "experiments/2026-07-AE01-post-n30-demand-composition-atlas/contracts/p2-i3/i05-br-calibration-launch-authorization.json",
            "--expected-head"
          ],
          "type": "array"
        },
        "owner_accepted_freeze": {"const": true}
