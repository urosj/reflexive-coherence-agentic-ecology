  "oneOf": [
    {"$ref": "#/$defs/matched_null"},
    {"$ref": "#/$defs/metric_calibration"},
    {"$ref": "#/$defs/frozen_metric_sheet"},
    {"$ref": "#/$defs/launch_authorization"},
    {"$ref": "#/$defs/attempt_claim"},
    {"$ref": "#/$defs/final_receipt"}
  ]
}
