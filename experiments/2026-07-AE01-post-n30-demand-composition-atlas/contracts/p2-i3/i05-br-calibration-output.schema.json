      "required": ["artifact_id", "artifact_version", "authority", "calibrated_relation_ids", "candidate_blind", "delta", "delta_scope", "evidence_effect", "lane_id", "measurement_resolution", "metric_id", "metric_sheet_id", "source_metric_sheet_sha256", "status"],
      "type": "object"
    },
    "launch_authorization": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {"const": "P2-I3-I05-BR-CALIBRATION-LAUNCH-AUTHORIZATION"},
        "artifact_version": {"const": "1.0.2"},
        "accepted_freeze_commit": {"$ref": "#/$defs/commit"},
        "attempt_claim_path": {"const": "experiments/2026-07-AE01-post-n30-demand-composition-atlas/outputs/p2-i3/i05/br-attempt-claim.json"},
        "authority_sha256": {"$ref": "#/$defs/authority_sha256"},
        "branch_id": {"const": "P2-I3-BR"},
        "calibration_invocation_authorized": {"const": true},
        "candidate_execution_authorized": {"const": false},
        "freeze_artifact_id": {"const": "P2-I3-I05-BR-CALIBRATION-INVOCATION-FREEZE"},
        "freeze_sha256": {"$ref": "#/$defs/sha256"},
        "governed_invocations_authorized": {"const": 1},
        "governed_paths": {"$ref": "#/$defs/governed_paths"},
        "interpreter_environment": {
          "additionalProperties": false,
          "properties": {
            "binary_sha256": {"$ref": "#/$defs/sha256"},
            "command": {"const": ".venv/bin/python"},
            "jsonschema": {"const": "4.26.0"},
            "process_environment": {"$ref": "#/$defs/process_environment"},
