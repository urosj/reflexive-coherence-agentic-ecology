        "authority": {"$ref": "#/$defs/authority"},
        "calibrated_relation_ids": {"$ref": "#/$defs/relation_ids"},
        "candidate_blind": {"const": true},
        "delta": {"$ref": "#/$defs/resolution"},
        "delta_scope": {"const": "shared_arithmetic_resolution_for_both_relations"},
        "evidence_effect": {"const": "numeric_measurement_resolution_only"},
        "lane_id": {"const": "AE01-L03"},
        "measurement_resolution": {"$ref": "#/$defs/resolution"},
        "metric_id": {"const": "trace_conditioned_route_normalized_margin"},
