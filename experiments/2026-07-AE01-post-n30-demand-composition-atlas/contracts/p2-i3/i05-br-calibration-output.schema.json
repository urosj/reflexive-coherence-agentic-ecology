{
  "$id": "urn:rcae:ae01:p2-i3:i05-br-calibration-output:1.0.2",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "Closed record shapes are supplemented by the digest-bound validate_calibration_outputs semantic validator for cross-record arithmetic and identity consistency.",
  "$defs": {
    "sha256": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
    "commit": {"pattern": "^[0-9a-f]{40}$", "type": "string"},
    "authority": {
      "additionalProperties": false,
      "properties": {
        "freeze_id": {"const": "P2-I3-I05-BR-CALIBRATION-INVOCATION-FREEZE"},
        "i04_source_anchor": {"const": "1097547ad30b77d4cf9312fb05753902f6d1cc81"},
        "policy_id": {"const": "P2-I3-I05-BR-ONE-SHOT-POLICY"}
      },
      "required": ["freeze_id", "i04_source_anchor", "policy_id"],
      "type": "object"
    },
    "relation_ids": {
      "const": ["m_trace", "m_export"],
      "type": "array"
    },
    "case_ids": {
      "const": ["EQ-NEG-HALF", "EQ-NEG-QUARTER", "EQ-ZERO", "EQ-POS-QUARTER", "EQ-POS-HALF"],
      "type": "array"
    },
    "excluded_ids": {
      "const": ["TRACE-FIRST-DOM-POS", "TRACE-SECOND-DOM-NEG", "EXPORT-FIRST-DOM-POS", "EXPORT-SECOND-DOM-NEG", "FLOOR-DOM-POS", "FLOOR-EQUALITY", "TRACE-CROSS-ZERO", "EXPORT-CROSS-ZERO"],
      "type": "array"
    },
    "rational_value": {
      "additionalProperties": false,
      "properties": {
        "rational": {"pattern": "^-?(0|[1-9][0-9]*)(/[1-9][0-9]*)?$", "type": "string"},
        "value": {"type": "number"}
      },
      "required": ["rational", "value"],
      "type": "object"
    },
    "process_environment": {
      "additionalProperties": false,
      "properties": {
        "PYTHONDONTWRITEBYTECODE": {"const": "1"},
        "PYTHONHASHSEED": {"const": "0"}
      },
      "required": ["PYTHONDONTWRITEBYTECODE", "PYTHONHASHSEED"],
      "type": "object"
    },
    "authority_sha256": {
      "additionalProperties": false,
      "properties": {
        "builder": {"$ref": "#/$defs/sha256"},
        "freeze": {"$ref": "#/$defs/sha256"},
        "output_schema": {"$ref": "#/$defs/sha256"},
        "policy": {"$ref": "#/$defs/sha256"},
        "validator": {"$ref": "#/$defs/sha256"},
        "wrapper": {"$ref": "#/$defs/sha256"}
      },
      "required": ["builder", "freeze", "output_schema", "policy", "validator", "wrapper"],
      "type": "object"
    },
    "resolution": {
      "additionalProperties": false,
      "properties": {
        "rational": {"const": "1/1000000000000"},
        "value": {"const": 1e-12}
      },
      "required": ["rational", "value"],
      "type": "object"
    },
    "positive_zero": {
      "additionalProperties": false,
      "properties": {
        "rational": {"const": "0"},
        "value": {"const": 0.0}
      },
      "required": ["rational", "value"],
      "type": "object"
    },
    "governed_paths": {
      "additionalProperties": false,
      "properties": {
        "attempt_claim": {"const": "experiments/2026-07-AE01-post-n30-demand-composition-atlas/outputs/p2-i3/i05/br-attempt-claim.json"},
        "final_receipt": {"const": "experiments/2026-07-AE01-post-n30-demand-composition-atlas/outputs/p2-i3/i05/br-final-receipt.json"},
        "frozen_metric_sheet": {"const": "experiments/2026-07-AE01-post-n30-demand-composition-atlas/outputs/p2-i3/i05/br-frozen-metric-sheet.json"},
        "matched_null": {"const": "experiments/2026-07-AE01-post-n30-demand-composition-atlas/outputs/p2-i3/i05/br-matched-null.json"},
        "metric_calibration": {"const": "experiments/2026-07-AE01-post-n30-demand-composition-atlas/outputs/p2-i3/i05/br-metric-calibration.json"}
      },
      "required": ["attempt_claim", "final_receipt", "frozen_metric_sheet", "matched_null", "metric_calibration"],
      "type": "object"
    },
    "null_case": {
      "additionalProperties": false,
      "properties": {
        "case_id": {"enum": ["EQ-NEG-HALF", "EQ-NEG-QUARTER", "EQ-ZERO", "EQ-POS-QUARTER", "EQ-POS-HALF"]},
        "response_records": {
          "items": {"$ref": "urn:rcae:p2-i3:br:i04:machine-records:1.0.1#/$defs/response_record"},
          "maxItems": 3,
          "minItems": 3,
          "type": "array"
        },
        "seed_alias": {"enum": [19, 43, 71, 109, 163]},
        "triplet_result": {"$ref": "urn:rcae:p2-i3:br:i04:machine-records:1.0.1#/$defs/triplet_result"}
      },
      "required": ["case_id", "response_records", "seed_alias", "triplet_result"],
      "type": "object"
    },
    "matched_null": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {"const": "P2-I3-I05-BR-MATCHED-NULL"},
        "artifact_version": {"const": "1.0.2"},
        "authority": {"$ref": "#/$defs/authority"},
        "candidate_artifacts_consumed": {"const": false},
        "candidate_execution_performed": {"const": false},
        "case_count": {"const": 5},
        "cases": {"items": {"$ref": "#/$defs/null_case"}, "maxItems": 5, "minItems": 5, "type": "array", "uniqueItems": true},
        "evidence_effect": {"const": "numeric_measurement_resolution_only"},
        "lane_id": {"const": "AE01-L03"},
        "pygrc_runtime_inputs_consumed": {"const": false},
        "randomness_used": {"const": false},
        "response_record_count": {"const": 15},
        "scientific_result": {"const": false}
      },
      "required": ["artifact_id", "artifact_version", "authority", "candidate_artifacts_consumed", "candidate_execution_performed", "case_count", "cases", "evidence_effect", "lane_id", "pygrc_runtime_inputs_consumed", "randomness_used", "response_record_count", "scientific_result"],
      "type": "object"
    },
    "metric_calibration": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {"const": "P2-I3-I05-BR-METRIC-CALIBRATION"},
        "artifact_version": {"const": "1.0.2"},
        "authority": {"$ref": "#/$defs/authority"},
        "calibrated_relation_ids": {"$ref": "#/$defs/relation_ids"},
        "candidate_blind": {"const": true},
        "delta": {"$ref": "#/$defs/resolution"},
        "delta_formula": {"const": "max(measurement_resolution, max(abs(m_trace[c]), abs(m_export[c])) for c in entered_case_ids)"},
        "entered_case_ids": {"$ref": "#/$defs/case_ids"},
        "entered_margin_count": {"const": 10},
        "entered_margins": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "case_id": {"enum": ["EQ-NEG-HALF", "EQ-NEG-QUARTER", "EQ-ZERO", "EQ-POS-QUARTER", "EQ-POS-HALF"]},
              "m_export": {"$ref": "#/$defs/rational_value"},
              "m_trace": {"$ref": "#/$defs/rational_value"}
            },
            "required": ["case_id", "m_export", "m_trace"],
            "type": "object"
          },
          "maxItems": 5,
          "minItems": 5,
          "type": "array"
        },
        "excluded_conformance_case_ids": {"$ref": "#/$defs/excluded_ids"},
        "lane_id": {"const": "AE01-L03"},
        "margins_per_case": {"additionalProperties": false, "properties": {"m_export": {"const": 1}, "m_trace": {"const": 1}}, "required": ["m_export", "m_trace"], "type": "object"},
        "matched_null_artifact_path": {"const": "experiments/2026-07-AE01-post-n30-demand-composition-atlas/outputs/p2-i3/i05/br-matched-null.json"},
        "maximum_absolute_matched_null_margin": {"$ref": "#/$defs/positive_zero"},
        "measurement_resolution": {"$ref": "#/$defs/resolution"},
        "scientific_result": {"const": false}
      },
      "required": ["artifact_id", "artifact_version", "authority", "calibrated_relation_ids", "candidate_blind", "delta", "delta_formula", "entered_case_ids", "entered_margin_count", "entered_margins", "excluded_conformance_case_ids", "lane_id", "margins_per_case", "matched_null_artifact_path", "maximum_absolute_matched_null_margin", "measurement_resolution", "scientific_result"],
      "type": "object"
    },
    "frozen_metric_sheet": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {"const": "P2-I3-I05-BR-FROZEN-METRIC-SHEET"},
