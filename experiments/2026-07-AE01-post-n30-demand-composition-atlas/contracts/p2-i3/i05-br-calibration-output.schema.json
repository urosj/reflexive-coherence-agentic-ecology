      "type": "object"
    },
    "attempt_claim": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {"const": "P2-I3-I05-BR-ATTEMPT-CLAIM"},
        "artifact_version": {"const": "1.0.2"},
        "accepted_freeze_commit": {"$ref": "#/$defs/commit"},
        "accepted_freeze_sha256": {"$ref": "#/$defs/sha256"},
        "activation": {"additionalProperties": false, "properties": {"artifact_id": {"const": "P2-I3-I05-BR-CALIBRATION-LAUNCH-AUTHORIZATION"}, "path": {"const": "experiments/2026-07-AE01-post-n30-demand-composition-atlas/contracts/p2-i3/i05-br-calibration-launch-authorization.json"}, "sha256": {"$ref": "#/$defs/sha256"}}, "required": ["artifact_id", "path", "sha256"], "type": "object"},
        "authorization_consumed": {"const": true},
        "bound_source_sha256": {"$ref": "#/$defs/authority_sha256"},
        "builder_invocation_ceiling": {"const": 1},
        "candidate_execution_authorized": {"const": false},
        "claim_id": {"const": "P2-I3-I05-BR-ATTEMPT-1"},
        "creation_disposition": {"const": "exclusive_pre_builder_attempt_consumption"},
        "governed_attempt": {"const": 1},
        "infrastructure_retries": {"const": 0},
        "interpreter": {"additionalProperties": false, "properties": {"binary_sha256": {"$ref": "#/$defs/sha256"}, "command": {"const": ".venv/bin/python"}, "implementation": {"const": "CPython"}, "jsonschema": {"const": "4.26.0"}, "pytest": {"const": "9.1.1"}, "version": {"const": "3.12.3"}}, "required": ["binary_sha256", "command", "implementation", "jsonschema", "pytest", "version"], "type": "object"},
        "launch_head": {"$ref": "#/$defs/commit"},
        "normalized_command": {"items": {"type": "string"}, "maxItems": 8, "minItems": 8, "type": "array"},
        "output_paths": {"$ref": "#/$defs/governed_paths"},
        "process_environment": {"$ref": "#/$defs/process_environment"}
