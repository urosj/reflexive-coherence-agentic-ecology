      "required": ["artifact_id", "artifact_version", "accepted_freeze_commit", "accepted_freeze_sha256", "activation", "authorization_consumed", "bound_source_sha256", "builder_invocation_ceiling", "candidate_execution_authorized", "claim_id", "creation_disposition", "governed_attempt", "infrastructure_retries", "interpreter", "launch_head", "normalized_command", "output_paths", "process_environment"],
      "type": "object"
    },
    "output_binding": {
      "additionalProperties": false,
      "properties": {"path": {"type": "string"}, "sha256": {"$ref": "#/$defs/sha256"}},
      "required": ["path", "sha256"],
      "type": "object"
    },
    "final_receipt": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {"const": "P2-I3-I05-BR-FINAL-RECEIPT"},
        "artifact_version": {"const": "1.0.2"},
        "activation_artifact_id": {"const": "P2-I3-I05-BR-CALIBRATION-LAUNCH-AUTHORIZATION"},
        "activation_sha256": {"$ref": "#/$defs/sha256"},
        "attempt_consumed": {"const": true},
        "builder_invocation_count": {"const": 1},
        "case_count": {"const": 5},
        "calibrated_relation_ids": {"$ref": "#/$defs/relation_ids"},
        "candidate_execution_authorized": {"const": false},
        "claim_id": {"const": "P2-I3-I05-BR-ATTEMPT-1"},
        "claim_sha256": {"$ref": "#/$defs/sha256"},
        "completion_status": {"const": "success"},
        "delta": {"$ref": "#/$defs/resolution"},
        "entered_margin_count": {"const": 10},
        "launch_head": {"$ref": "#/$defs/commit"},
        "output_bindings": {"additionalProperties": false, "properties": {"frozen_metric_sheet": {"$ref": "#/$defs/output_binding"}, "matched_null": {"$ref": "#/$defs/output_binding"}, "metric_calibration": {"$ref": "#/$defs/output_binding"}}, "required": ["frozen_metric_sheet", "matched_null", "metric_calibration"], "type": "object"},
        "readback_validation": {"const": "passed_exact_bytes_canonical_json_and_semantics"},
        "response_record_count": {"const": 15},
        "schema_validation": {"const": "passed"},
        "scientific_result": {"const": false},
        "second_start_evidence": {"additionalProperties": false, "properties": {"attempted": {"const": true}, "claim_sha256_unchanged": {"const": true}, "refusal_reason": {"const": "attempt_claim_exists"}, "refused": {"const": true}}, "required": ["attempted", "claim_sha256_unchanged", "refusal_reason", "refused"], "type": "object"},
        "semantic_validation": {"const": "passed"},
        "triplet_count": {"const": 5}
      },
      "required": ["artifact_id", "artifact_version", "activation_artifact_id", "activation_sha256", "attempt_consumed", "builder_invocation_count", "case_count", "calibrated_relation_ids", "candidate_execution_authorized", "claim_id", "claim_sha256", "completion_status", "delta", "entered_margin_count", "launch_head", "output_bindings", "readback_validation", "response_record_count", "schema_validation", "scientific_result", "second_start_evidence", "semantic_validation", "triplet_count"],
      "type": "object"
    }
