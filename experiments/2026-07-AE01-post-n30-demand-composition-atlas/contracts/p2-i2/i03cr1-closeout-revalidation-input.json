  "acceptance_statements": [
    {"id": "AT-01", "text": "The hybrid carrier is the bound P plus authoritative H_P/M_H output-port composite and common access relation, not an ad hoc query."},
    {"id": "AT-02", "text": "H_P remains persistent and authoritative and M_H is a verified output port, so the architecture is not silently reduced to state-only P/M_H."},
    {"id": "AT-03", "text": "P enters the native joint path independently and is not encoded in R_H."},
    {"id": "AT-04", "text": "H_P enters independently through R_H/M_H and is unchanged by the P-only intervention."},
    {"id": "AT-05", "text": "A complete qualitative P-reference/candidate by H-reference/candidate causal structure is frozen."},
    {"id": "AT-06", "text": "Hybrid meaning does not depend only on the conformance threshold."},
    {"id": "AT-07", "text": "The neutral contact is common, causally neutral, inadmissible to H_P, latest before feedback, and has no digest authorization role."},
    {"id": "AT-08", "text": "Materialization, debit, neutral, feedback, response, reset/load, private, and diversion traffic cannot self-admit into H_P."},
    {"id": "AT-09", "text": "Token type and admission keys do not encode arbitrary contributor identity."},
    {"id": "AT-10", "text": "The private competitor has no hidden common read or cross-pairing."},
    {"id": "AT-11", "text": "The adapter never computes P plus M_H, threshold, success, or later scheduling."},
    {"id": "AT-12", "text": "Layered identity binds both components, joint/private masks, neutral-contact policy, adapter current/reset state, code/configuration, fixture/freeze, and paired native reset baseline."},
    {"id": "AT-13", "text": "H_P-to-M_H consistency is verified before response and continuation and disagreement fails closed."},
    {"id": "AT-14", "text": "Capacity and lifecycle obligations have explicit dispositions."},
    {"id": "AT-15", "text": "All conformance values and outcomes are machine-registered for later rejection and remain quarantined."},
    {"id": "AT-16", "text": "I03A and I03B remain unchanged, separately retained, and unranked."},
    {"id": "AT-17", "text": "Owner acceptance may open only a separately declared umbrella I03 family closeout; I04 remains closed until that closeout passes."}
