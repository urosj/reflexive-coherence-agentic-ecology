  "comparison_questions": [
    {
      "question_id": "I03B-Q01",
      "question": "Which exact model-owned or producer-owned object would be the active common causal history H_P, distinct from encounter state C_P and audit-only lineage L?"
    },
    {
      "question_id": "I03B-Q02",
      "question": "Can two attributable contributions jointly constitute H_P without preserving contributor-private mailboxes or a controller-authored success field?"
    },
    {
      "question_id": "I03B-Q03",
      "question": "Does the later response read H_P through one common non-private access path while encounter-time carrier state is matched?"
    },
    {
      "question_id": "I03B-Q04",
      "question": "Can a history-only intervention alter H_P and the later response while preserving registered marginal contributions, encounter state, support, opportunity, and audit attribution?"
    },
    {
      "question_id": "I03B-Q05",
      "question": "Can a state-only intervention alter encounter state without changing H_P, so history dependence is separated from the accepted state-carried profile?"
    },
    {
      "question_id": "I03B-Q06",
      "question": "Which history components are active causal inputs, which are audit-only, and which forbidden labels/controller fields are absent from the response path?"
    },
    {
      "question_id": "I03B-Q07",
      "question": "Does native restoration identity cover the selected active history and reset baseline, or what explicit RCAE composite identity is required?"
    },
    {
      "question_id": "I03B-Q08",
      "question": "Are native public interfaces adequate; if not, what is the minimal separable RCAE producer boundary, or which prerequisite is missing?"
    },
    {
      "question_id": "I03B-Q09",
      "question": "How do all seven logical cells, five L02 controls, OP-01..OP-09, private partitions, access witness, and equal-input continuation project into history_carried mode without rewriting state_carried?"
    }
  ],
  "candidate_dispositions": [
    {
      "realization_class": "pygrc_native_candidate",
      "admission_rule": "Every active-history mutation, common-history read, response transition, intervention, and restoration-relevant state is owned by admitted public PyGRC machinery; RCAE supplies declarative roles/orchestration/guards only."
    },
    {
      "realization_class": "minimally_producer_assisted",
      "admission_rule": "PyGRC lacks one necessary active-history transition or read, and one explicitly frozen RCAE producer supplies only that missing separable operation without computing both pool history and success."
    },
    {
      "realization_class": "missing_prerequisite",
      "admission_rule": "No bounded native or separable producer-assisted realization can preserve common history, matched state, history intervention, access, restoration, and no-controller guards."
    }
  ],
  "selection_order": [
    "pygrc_native_candidate",
    "minimally_producer_assisted",
    "missing_prerequisite"
  ],
